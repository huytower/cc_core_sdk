# App Configuration
APP_NAME=MyApp

# Routing Configuration
AUTO_ROUTE_START=COMMENT

# API Configuration
API_URL=https://api.example.com

# Feature Flags
ENABLE_LOGGER=false
ENABLE_LOGGER_DIO=false

ENABLE_CRASH_LOG_UPLOAD=true
CRASH_LOG_API_PATH=/client-logs
ENABLE_DEV_CRASH_LOG_VIEWER=false
# Production Environment Variables
# Add your production environment variables here

# Example:
# API_URL=https://api.example.com
# API_KEY=your_prod_api_key
