# App Configuration
APP_NAME='MyApp (UAT)'

# Routing Configuration
AUTO_ROUTE_START=COMMENT

# API Configuration
API_URL=https://api-uat.example.com

# Feature Flags
ENABLE_LOGGER=true
ENABLE_LOGGER_DIO=true

ENABLE_CRASH_LOG_UPLOAD=true
CRASH_LOG_API_PATH=/client-logs
ENABLE_DEV_CRASH_LOG_VIEWER=false
# UAT Environment Variables
# Add your UAT environment variables here

# Example:
# API_URL=https://uat-api.example.com
# API_KEY=your_uat_api_key
