# App Configuration
APP_NAME='FREE_FAKE_API'

# Routing Configuration
#AUTO_ROUTE_START=NO_QUICK_TEST
AUTO_ROUTE_START=QUICK_TEST# NOTICE: enable this line when do a quick test to specific UI Page, display as 2nd tab

# API Configuration
API_URL=https://jsonplaceholder.typicode.com

# Feature Flags
ENABLE_LOGGER=true
ENABLE_LOGGER_DIO=true

# Crash logs (catcher_2): uploaded on next app start
ENABLE_CRASH_LOG_UPLOAD=true
CRASH_LOG_API_PATH=/client-logs
# Long-press log viewer in release builds (optional)
ENABLE_DEV_CRASH_LOG_VIEWER=false
