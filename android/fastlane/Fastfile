default_platform(:android)

platform :android do
  desc "Build AAB and distribute to Firebase App Distribution"
  # Usage: fastlane distribute_firebase flavor:uat
  lane :distribute_firebase do |options|
    flavor = options[:flavor] || "uat"

    # 1. Generate code (run from root directory)
    # Use direct Flutter command instead of melos to avoid PATH issues
    sh("cd ../.. && flutter pub run build_runner build --delete-conflicting-outputs")

    # 2. Build the Flutter App Bundle
    # We move up to the root to run flutter commands
    sh("cd ../.. && flutter build appbundle --release --flavor #{flavor}")

    # 3. Upload to Firebase
    # Assumes FIREBASE_APP_ID is in your environment variables
    # You need the 'fastlane-plugin-firebase_app_distribution' plugin
    firebase_app_distribution(
      app: ENV["FIREBASE_APP_ID_ANDROID"],
      groups: ENV["FIREBASE_GROUPS"] || "testers",
      release_notes: "Built with Fastlane from CI",
      android_artifact_type: "AAB",
      android_artifact_path: "../build/app/outputs/bundle/#{flavor}Release/app-#{flavor}-release.aab"
    )
  end

  desc "Build and sign the release AAB for Play Store"
  lane :build_release do
    # 1. Generate code (run from root directory)
    sh("cd ../.. && flutter pub run build_runner build --delete-conflicting-outputs")
    
    # 2. Build the Flutter App Bundle
    sh("cd ../.. && flutter build appbundle --release --flavor prod")
  end
end
